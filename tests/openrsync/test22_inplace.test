#! /bin/sh

. ${tstdir-.}/lib.sh
. ${tstdir-.}/conf.sh

fails=0

rm -rf dir1 dir2 dir3
# Make a new dir with all of the interesting things
mkdir dir1
cd dir1
touch a_file
ln a_file hardlink
echo "Hello, world" >> a_file

cd ..
mkdir dir2
cd dir2
touch a_file
ln a_file hardlink
echo "Hello, my friends" >> a_file

cd ..
rsync -a --inplace -- dir1/ dir2 2> l2

# Make sure it didn't break the hardlink
case $(uname -s) in
Linux)
	ino1=$(stat -c "%i" dir2/a_file)
	ino2=$(stat -c "%i" dir2/hardlink)
	;;
*)
	ino1=$(stat -f "%i" dir2/a_file)
	ino2=$(stat -f "%i" dir2/hardlink)
	;;
esac

if ! test "$ino1" -eq "$ino2"; then
	1>&2 echo "FAIL: hardlink broken"
	fails=$((fails + 1))
fi

if ! cmp -s dir1/a_file dir2/a_file; then
	1>&2 echo "FAIL: file transferred incorrectly"
	fails=$((fails + 1))
fi

rm -rf dir1 dir2 dir3
mkdir -p dir1 dir2

# On the second transfer here, bad tracking of the file position would have
# resulted in dir2/a_file being truncated.
dd if=/dev/random of=dir1/a_file bs=8m count=4 conv=sync
rsync -a --inplace --no-W dir1/ dir2
cmp dir1/a_file dir2/a_file
rsync -aI --inplace --no-W dir1/ dir2
cmp dir1/a_file dir2/a_file

exit $fails
