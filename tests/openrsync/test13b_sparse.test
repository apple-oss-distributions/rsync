#! /bin/sh

set -e
set -u

. ${tstdir-.}/lib.sh
. ${tstdir-.}/conf.sh

mksparse=${tstdir-.}/mksparse

rm -rf dir1 dir2 sparsefile
# make the copy-from-here tree
mkdir dir1
# True sparse file.
$mksparse -c -h 8192 -d 2 dir1/sparsefile
$mksparse -r dir1/sparsefile > sparsefile.report
if [ ! -s sparsefile.report ]; then
	1>&2 echo "Failed to sparsify our initial file"
	exit 1
fi

mkdir dir2

# Transfer a sparse file with --sparse and ensure that it doesn't regress in
# the process.
rsync -a --sparse -- dir1/ dir2
$mksparse -r dir2/sparsefile > dir2/sparsefile.report
cmp sparsefile.report dir2/sparsefile.report
